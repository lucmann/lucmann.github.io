digraph mesadri3 {
    compound=true
    newrank=true
    node [shape=box]

    colorbuffer [label="", image="window-content.png", imagescale=true]
    windowframe [label="", image="window-frame.png", imagescale=true]
    subgraph cluster_glxgears {
        label="glxgears"
        direction=TB
        color   [label="Color Buffer BO\n(pipe_resource)", style=filled, fillcolor=lightskyblue] 
        export  [label="resource_get_handle", shape=plaintext]
        prime   [label="drmPrimeHandleToFD", shape=plaintext]
        
        color -> export -> prime
    }
    subgraph cluster_x11 {
        label="Xorg"
        pixmap [label="Pixmap"]
        glamor [label="glamor_pixmap_from_fds", shape=plaintext]
        proc   [label="proc_dri3_pixmap_from_buffers", shape=plaintext]

        pixmap -> glamor [dir=back, color=lightskyblue]
        glamor -> proc   [dir=back, color=lightskyblue]
    }
    subgraph cluster_kwin_x11 {
        label="kwin_x11"
        decoration [label="Window Frame"]
        texture [label="GLTexture", style=filled, fillcolor=lightskyblue]
        subgraph cluster_tfp {
            label="GLX_EXT_texture_from_pixmap"
            glx_bind [label="glXBindTexImageExt", shape=plaintext]
            glx_pixmap [label="glXCreatePixmap", shape=plaintext]
            xcb_dri3 [label="XCB_DRI3_BUFFER_FROM_PIXMAP", shape=plaintext]
        }
        
        texture    -> glx_bind   [dir=back]
        glx_bind   -> glx_pixmap [dir=back]
        glx_pixmap -> xcb_dri3   [dir=back]
    }
    
    {rank=same; colorbuffer,windowframe}
    {rank=same; color,pixmap,texture}
    
    texture -> pixmap -> colorbuffer [style=invis]
    colorbuffer -> color
    colorbuffer -> pixmap [style=dashed]
    colorbuffer -> texture
    windowframe -> decoration
    prime  -> proc  [xlabel="domain_socket(FD)",label="XCB_DRI3_PIXMAP_FROM_BUFFERS", color=lightskyblue]
    pixmap -> xcb_dri3 [xlabel="xcb_composite_name_window_pixmap(XID)", color=lightskyblue]    

}
